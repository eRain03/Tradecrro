# Data Source Configuration
# =============================
# 选择数据源: yahoo | tiger | simulated
# yahoo = Yahoo Finance (免费，无需API Key) ⭐ 推荐
# tiger = 老虎交易平台 API (需要购买行情权限，更稳定可靠)
# simulated = 模拟数据 (用于测试)
DATA_SOURCE=yahoo

# Tiger Open API Configuration (for DATA_SOURCE=tiger)
# =============================
# 需要本机安装 Python3 并执行: pip install -r server/requirements-tiger.txt
# 需要在老虎开发者平台申请 API 权限: https://developer.itigerup.com
# 需要单独购买行情权限（独立于 APP 权限）
#
# 配置文件路径（相对于 server 目录）
TIGER_CONFIG_PATH=./config/tiger_openapi_config.properties
TIGER_PYTHON=python3

# Databento（仅用于 /api/backtest/replay 回测拉历史 K 线，不影响实时轮询）
# 需要本机安装 Python3 并执行: pip install -r server/requirements-databento.txt
# DATABENTO_API_KEY=你的密钥_勿提交到git
# DATABENTO_DATASET=DBEQ.BASIC
# DATABENTO_PYTHON=python3

# IG Markets API Configuration (only needed if DATA_SOURCE=ig)
# =============================

# 选择环境: demo 或 live
IG_ENV=demo

# 模拟账户配置
IG_DEMO_API_KEY=your_demo_api_key_here
IG_DEMO_USERNAME=your_demo_username
IG_DEMO_PASSWORD=your_demo_password

# 实盘账户配置（后续使用）
IG_LIVE_API_KEY=your_live_api_key_here
IG_LIVE_USERNAME=your_live_username
IG_LIVE_PASSWORD=your_live_password

# 服务器配置
# =============================
PORT=3001
NODE_ENV=development

# 数据库配置
DATABASE_PATH=./data/trading.db

# WebSocket配置
WS_PORT=3002

# 交易配置
# =============================
# 评分门槛
SCORE_THRESHOLD=87
# 最大仓位比例 (%)
MAX_POSITION_PCT=10
# 止盈比例 (%)
TAKE_PROFIT_PCT=200
# 止损比例 (%)
STOP_LOSS_PCT=50
# 数据采样间隔 (秒)
SAMPLING_INTERVAL=30
# 回溯窗口 (分钟)
LOOKBACK_WINDOW=30
# 滞后间隔 (intervals, 1分钟 = 2个30秒)
LAG_INTERVALS=2
# 交易对上限
MAX_PAIRS=400

# 自动交易配置
# =============================
# ⚠️ 警告: 开启后将执行真实交易！
# 是否启用自动交易 (true/false)
AUTO_TRADING_ENABLED=false
# 是否为模拟运行 (true=只记录不交易, false=真实交易)
AUTO_TRADING_DRY_RUN=true
# 最大持仓数量 (股数)
MAX_POSITION_SIZE=100
# 最大持仓金额 (美元)
MAX_POSITION_VALUE=10000
